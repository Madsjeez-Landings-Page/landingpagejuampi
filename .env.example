# URL pública (HTTPS). Coincide con dominio en Railway.
NEXT_PUBLIC_SITE_URL=https://formulaagencia.com

# --- Panel de leads (/admin) — Railway ---
# Contraseña para Juampi (larga y única; no la subas al repo)
ADMIN_PASSWORD=
# Opcional: refuerza la cookie de sesión
ADMIN_SESSION_SECRET=

# Persistencia en Railway: creá un Volume montado en /data y usá:
LEADS_DATA_FILE=/data/leads.json
# En local (sin variable) se usa: data/leads.json

# Si el build en Railway sigue usando Node 18, en Variables agregá:
# NIXPACKS_NODE_VERSION=22 (tipo: build o "add to all" según Railway)

# Opcional: si en Deploy Logs ves "Failed to find Server Action ... older or newer deployment",
# Next.js recomienda fijar esta clave (misma en cada build/replica). Base64 de 16/24/32 bytes.
# Generar (una vez): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# En Railway: Variable disponible para Build + Deploy (no la subas al repo).
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Opcional: copia por email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=
