# --- Panel de leads (/admin) ---
# Contraseña para que Juampi entre al panel (elegí una larga y única)
ADMIN_PASSWORD=
# Opcional: refuerza la cookie de sesión (si no se define, se usa ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=

# Persistencia de leads en producción (Vercel Blob)
# En local se guarda en data/leads.json sin configurar nada.
# En Vercel: Storage → Blob → Create → copiá el token READ_WRITE
BLOB_READ_WRITE_TOKEN=

# Opcional: copia por email con Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=
