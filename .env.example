# Opcional: envío de leads del formulario por Resend (https://resend.com)
# Sin estas variables, el POST /api/contact igual responde OK y el lead se registra en consola del servidor.
RESEND_API_KEY=
# Remitente verificado en Resend (ej. onboarding@resend.dev en pruebas o notificaciones@tudominio.com)
RESEND_FROM_EMAIL=
# Bandeja donde querés recibir los leads (ej. tu mail de trabajo)
CONTACT_TO_EMAIL=
